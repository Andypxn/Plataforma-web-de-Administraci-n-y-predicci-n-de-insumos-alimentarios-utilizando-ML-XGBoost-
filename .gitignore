# 🚀 SmartPOS: .gitignore Maestro
# ------------------------------

# --- Archivos Sensibles y Configuración ---
.env
.env.production
!.env.example
credentials.json
secrets.xml

# --- Java (Spring Boot / Maven) ---
**/target/
**/*.jar
**/*.war
**/*.ear
**/*.class
.mvn/wrapper/*.jar
.mvn/
**/mvnw
**/mvnw.cmd
HELP.md

# --- Node.js (React / Frontend) ---
**/node_modules/
**/dist/
**/dist-ssr/
**/build/
**/coverage/
.eslintcache
.stylelintcache
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --- Python (ML Service & Analysis) ---
**/venv/
**/.venv/
**/env/
**/bin/
**/lib/
**/include/
**/share/
**/*.pyc
**/*.pyo
**/*.pyd
**/__pycache__/
**/.pytest_cache/
**/.coverage
**/htmlcov/
**/*.pkl
**/*.joblib
**/*.model
**/*.h5
**/*.ipynb_checkpoints/
ml-prediction-service/coverage.xml

# --- Análisis de Tesis y Datos ---
analisis-tesis-xgboost/data/*.csv
analisis-tesis-xgboost/results/*.png
analisis-tesis-xgboost/results/*.pdf
analisis-tesis-xgboost/models/*.pkl
reportes-predicciones/evaluacion_*

# --- Docker ---
.docker/
**/data/pgdata/

# --- IDEs y Sistemas Operativos ---
.vscode/
.idea/
*.iws
*.iml
*.ipr
*.sln
*.swp
*.swo
.DS_Store
Thumbs.db

# --- Logs ---
*.log
logs/
